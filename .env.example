# Only these two are needed for the React app (Vercel + local)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_jwt_key_here

# Email (Resend) — server-side only, NEVER use VITE_ prefix
RESEND_API_KEY=re_your_resend_api_key
ADMIN_EMAIL=support@zyvotrix.com
FROM_EMAIL=Zyvotrix <onboarding@resend.dev>

# Do NOT add postgres password, service_role, or jwt_secret with VITE_ prefix.
# Those would be exposed in the browser bundle.

# Local payment testing: run `npm run dev:full` (Express :3001 + Vite proxy for /api)
# Production (Vercel): set RAZORPAY_LIVE_KEY_ID + RAZORPAY_LIVE_KEY_SECRET (server).
# The checkout key is returned from /api/create-order — VITE_RAZORPAY_LIVE_KEY_ID is optional.

# Supabase service role — server-side only (complete-enrollment workflow)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Razorpay — local dev uses TEST keys automatically; Vercel production uses LIVE
# Optional override: RAZORPAY_MODE=test|live
RAZORPAY_MODE=test

RAZORPAY_TEST_KEY_ID=rzp_test_your_test_key
RAZORPAY_TEST_KEY_SECRET=your_test_secret
RAZORPAY_TEST_WEBHOOK_SECRET=your_test_webhook_secret

RAZORPAY_LIVE_KEY_ID=rzp_live_your_live_key
RAZORPAY_LIVE_KEY_SECRET=your_live_secret
RAZORPAY_LIVE_WEBHOOK_SECRET=your_live_webhook_secret

VITE_RAZORPAY_TEST_KEY_ID=rzp_test_your_test_key
VITE_RAZORPAY_LIVE_KEY_ID=rzp_live_your_live_key
# Optional frontend override: VITE_RAZORPAY_MODE=test|live
# Optional: protect local Express admin routes (server.js)
# ADMIN_API_KEY=your_random_secret_key
# COMMUNITY_DISCORD / COMMUNITY_WHATSAPP / COMMUNITY_TELEGRAM (server-side emails)

# Optional: community invite links (shown on homepage when set)
# VITE_COMMUNITY_DISCORD=https://discord.gg/your-invite
# VITE_COMMUNITY_WHATSAPP=https://chat.whatsapp.com/your-group
# VITE_COMMUNITY_TELEGRAM=https://t.me/your_channel
